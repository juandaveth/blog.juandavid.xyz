---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="es">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<h1>Hola, soy Juan David</h1>
			<p>
				Aquí escribo sobre lo que voy aprendiendo y construyendo. Puedes leer los artículos en el <a href="/posts">blog</a> o conocer más en <a href="/ahora">ahora</a>.
			</p>

			<div class="update-notice">
				🌐 <strong>Estoy activo en estos lugares en internet:</strong>
			</div>

			<ul class="social-links">
				<li>
					<a href="https://www.linkedin.com/in/jdreyespaez" target="_blank" rel="noopener noreferrer">
						<svg viewBox="0 0 24 24" width="22" height="22" aria-hidden="true">
							<path
								fill="currentColor"
								d="M20.45 20.45h-3.56v-5.57c0-1.33-.02-3.04-1.85-3.04-1.85 0-2.14 1.45-2.14 2.94v5.67H9.34V9h3.41v1.56h.05c.48-.9 1.64-1.85 3.38-1.85 3.6 0 4.27 2.37 4.27 5.46v6.28ZM5.34 7.43a2.07 2.07 0 1 1 0-4.14 2.07 2.07 0 0 1 0 4.14ZM7.12 20.45H3.56V9h3.56v11.45ZM22.22 0H1.77C.8 0 0 .78 0 1.75v20.5C0 23.22.8 24 1.77 24h20.45c.98 0 1.78-.78 1.78-1.75V1.75C24 .78 23.2 0 22.22 0Z"
							></path>
						</svg>
						<span>LinkedIn</span>
					</a>
				</li>
				<li>
					<a href="https://instagram.com/juandavid.xyz" target="_blank" rel="noopener noreferrer">
						<svg viewBox="0 0 24 24" width="22" height="22" aria-hidden="true">
							<path
								fill="currentColor"
								d="M12 2.16c3.2 0 3.58.01 4.85.07 1.17.05 1.8.25 2.23.41.56.22.96.48 1.38.9.42.42.68.82.9 1.38.16.42.36 1.06.41 2.23.06 1.27.07 1.65.07 4.85s-.01 3.58-.07 4.85c-.05 1.17-.25 1.8-.41 2.23-.22.56-.48.96-.9 1.38-.42.42-.82.68-1.38.9-.42.16-1.06.36-2.23.41-1.27.06-1.65.07-4.85.07s-3.58-.01-4.85-.07c-1.17-.05-1.8-.25-2.23-.41-.56-.22-.96-.48-1.38-.9-.42-.42-.68-.82-.9-1.38-.16-.42-.36-1.06-.41-2.23-.06-1.27-.07-1.65-.07-4.85s.01-3.58.07-4.85c.05-1.17.25-1.8.41-2.23.22-.56.48-.96.9-1.38.42-.42.82-.68 1.38-.9.42-.16 1.06-.36 2.23-.41 1.27-.06 1.65-.07 4.85-.07ZM12 0C8.74 0 8.33.01 7.05.07 5.78.13 4.9.33 4.14.63c-.79.31-1.46.72-2.13 1.39-.67.67-1.08 1.34-1.39 2.13-.3.76-.5 1.64-.56 2.91C.01 8.33 0 8.74 0 12s.01 3.67.07 4.95c.06 1.27.26 2.15.56 2.91.31.79.72 1.46 1.39 2.13.67.67 1.34 1.08 2.13 1.39.76.3 1.64.5 2.91.56 1.28.06 1.69.07 4.95.07s3.67-.01 4.95-.07c1.27-.06 2.15-.26 2.91-.56.79-.31 1.46-.72 2.13-1.39.67-.67 1.08-1.34 1.39-2.13.3-.76.5-1.64.56-2.91.06-1.28.07-1.69.07-4.95s-.01-3.67-.07-4.95c-.06-1.27-.26-2.15-.56-2.91-.31-.79-.72-1.46-1.39-2.13-.67-.67-1.34-1.08-2.13-1.39-.76-.3-1.64-.5-2.91-.56C15.67.01 15.26 0 12 0Zm0 5.84A6.16 6.16 0 1 0 18.16 12 6.16 6.16 0 0 0 12 5.84ZM12 16a4 4 0 1 1 0-8 4 4 0 0 1 0 8Zm6.41-10.84a1.44 1.44 0 1 1-2.88 0 1.44 1.44 0 0 1 2.88 0Z"
							></path>
						</svg>
						<span>Instagram</span>
					</a>
				</li>
				<li>
					<a href="https://x.com/juandaveth" target="_blank" rel="noopener noreferrer">
						<svg viewBox="0 0 24 24" width="22" height="22" aria-hidden="true">
							<path
								fill="currentColor"
								d="M18.9 1.15h3.68l-8.04 9.19 9.46 12.51h-7.4l-5.8-7.58-6.64 7.58H.48l8.6-9.83L0 1.15h7.59l5.24 6.93 6.07-6.93Zm-1.29 19.46h2.04L6.49 3.23H4.3l13.31 17.38Z"
							></path>
						</svg>
						<span>X</span>
					</a>
				</li>
				<li>
					<a href="https://github.com/juandaveth" target="_blank" rel="noopener noreferrer">
						<svg viewBox="0 0 16 16" width="22" height="22" aria-hidden="true">
							<path
								fill="currentColor"
								d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.012 8.012 0 0 0 16 8c0-4.42-3.58-8-8-8Z"
							></path>
						</svg>
						<span>GitHub</span>
					</a>
				</li>
			</ul>

			<div class="update-notice">
				🕰️ <strong>Última actualización:</strong> 21 de junio, 2026.
			</div>

			<div class="intro-text">
				<p>Las etiquetas expiran si no se ponen en práctica.</p>

				<p>
					No me llamo economista. Tengo un título de profesional en Economía desde 2012, pero no
					lo he ejercido. Prefiero la palabra "ejercitación" a "teoría". No puedo reivindicar un
					título que no he puesto en práctica.
				</p>

				<p>
					Tampoco soy nómada digital, aunque lo fui entre 2016 y 2017. Ahora vivo en Medellín y me
					muevo de otras formas. En su momento <a
						href="https://juandaveth.medium.com/25-diciembre-a-25-de-agosto-10-meses-10-pa%C3%ADses-10-aprendizajes-483826ba8793"
						>escribía</a
					> sobre esa etapa de viajes. Eso fue útil entonces. Ahora construyo raíces en otro lugar.
				</p>
			</div>

			<div class="section">
				<h2>Ahora mismo</h2>

				<p class="section-intro">En los últimos meses empleo mi tiempo laboral siendo:</p>

				<div class="item">
					<span class="emoji">✍🏼</span>
					<p><strong>Escritor</strong>, me dedico a hacer historias familiares. Pronto anunciaré ese proyecto.</p>
				</div>

				<div class="item">
					<span class="emoji">🤝</span>
					<p>
						<strong>Gestor de comunidades</strong>, creé <a href="https://conectenis.com"
							>conectenis.com</a
						> para poder jugar más partidos de tenis al llegar a una nueva ciudad.
					</p>
				</div>

				<div class="item">
					<span class="emoji">🫙</span>
					<p><strong>Fermentero</strong>, con un parche nos reunimos cada 15 días a hacer fermentos en El Escampadero.</p>
				</div>

				<p class="section-intro spaced">Llevo un buen tiempo disfrutando la vida siendo:</p>

				<div class="item">
					<span class="emoji">🚵🏻</span>
					<p><strong>Ciclista</strong>, corrí mi primer fondo en la Ruta Medellín y he hecho bikepacking en Antioquia, con mi amigo Thomas y sólo.</p>
				</div>

				<div class="item">
					<span class="emoji">🎾</span>
					<p><strong>Tenista</strong>, juego por lo menos una vez a la semana.</p>
				</div>

				<div class="item">
					<span class="emoji">🏊🏻‍♂️</span>
					<p><strong>Nadador de aguas abiertas</strong>, participaré en el Oceanman de República Dominicana.</p>
				</div>
			</div>

			<div class="section">
				<h2>Pasado reciente</h2>

				<p class="section-intro">Hace poco empleo mi tiempo siendo:</p>

				<div class="item">
					<span class="emoji">🧵</span>
					<p>
						<strong>Tejedor</strong>, trabajé con <a href="https://www.ethkipu.org/">ETH Kipu</a> conectando
						gente a través de Educación Web3.
					</p>
				</div>

				<div class="item">
					<span class="emoji">👨‍🏫</span>
					<p>
						<strong>Profesor</strong>, facilité cursos de programación en Solidity: <a
							href="https://www.ethkipu.org/#impacto">Ethereum Developer Pack</a
						>.
					</p>
				</div>

				<div class="item">
					<span class="emoji">✍🏼</span>
					<p>
						<strong>Escritor de Ethereum</strong>, <a href="https://typeshare.co/juandaveth"
							>publiqué textos</a
						> en inglés sobre Ethereum además de artículos en este <a
							href="https://blog.juandavid.xyz">blog</a
						> en español.
					</p>
				</div>

				<p class="section-intro spaced">Hace unos años ponía en práctica mis habilidades como:</p>

				<div class="item">
					<span class="emoji">🎧</span>
					<p>
						<strong>Productor del podcast</strong> <a
							href="https://open.spotify.com/show/6XfSNjTdLzyTugC1OMAIqL?si=d48d0d7fdcd54c6e"
							>En Caso de Cáncer</a
						>. Para los más visuales hay <a href="https://www.instagram.com/encasodecancer/"
							>Instagram</a
						>.
					</p>
				</div>

				<div class="item">
					<span class="emoji">🛖</span>
					<p>
						<strong>Cocinero</strong> de <a href="https://www.instagram.com/p/CVjQkaXJtf_/"
							>cenas clandestinas</a
						> en <a href="https://www.instagram.com/lacasadivergente/">La Casa Divergente</a>, donde
						también viví.
					</p>
				</div>

				<div class="item">
					<span class="emoji">👾</span>
					<p>
						<strong>Organizador</strong> de <a href="https://youtu.be/_Md41SbJKMM"
							>conferencias sobre Ethereum</a
						> y <a href="https://youtu.be/0F5CWJKp6Lw">hackatones Web3</a>.
					</p>
				</div>
			</div>

			<div class="section">
				<h2>Conectar</h2>

				<div class="item">
					<p>
						Estoy activo en <a href="https://instagram.com/juandavid.xyz">Instagram @juandavid.xyz</a> y <a href="https://t.me/juandaveth">Telegram</a>.
					</p>
				</div>
			</div>

			<div class="now-footer">
				<p>
					Esta es mi página <a href="https://nownownow.com/about">/now</a> como propone <a
						href="https://sive.rs/now">Derek Sivers</a
					>, un amigo de internet.
				</p>
			</div>
		</main>
		<Footer />
	</body>
</html>

<style>
	.social-links {
		display: grid;
		grid-template-columns: repeat(2, 1fr);
		gap: 1rem;
		list-style: none;
		margin: 1.5em 0;
		padding: 0;
	}
	.social-links li {
		min-width: 0;
	}
	.social-links a {
		display: flex;
		align-items: center;
		justify-content: center;
		gap: 0.6em;
		box-sizing: border-box;
		width: 100%;
		padding: 0.9em 1.2em;
		border: 1px solid rgb(var(--gray-light));
		border-radius: 999px;
		font-size: 1rem;
		text-decoration: none;
		color: rgb(var(--gray-dark));
	}
	.social-links a:hover {
		border-color: var(--accent);
		color: var(--accent);
	}
	.social-links svg {
		flex-shrink: 0;
	}
	@media (max-width: 480px) {
		.social-links {
			grid-template-columns: 1fr;
		}
	}
	.update-notice {
		background: rgb(var(--gray-light));
		padding: 0.8em 1.2em;
		border-left: 4px solid var(--accent);
		margin: 1.5em 0;
		font-size: 0.9rem;
		color: rgb(var(--gray-dark));
	}
	.intro-text p {
		margin-bottom: 1em;
	}
	.section {
		margin-bottom: 2.5em;
	}
	.section-intro {
		color: rgb(var(--gray));
		margin-bottom: 1em;
	}
	.section-intro.spaced {
		margin-top: 1.5em;
	}
	.item {
		display: flex;
		gap: 0.7em;
		align-items: flex-start;
		margin-bottom: 1em;
	}
	.item p {
		margin: 0;
	}
	.emoji {
		font-size: 1.3em;
		flex-shrink: 0;
		min-width: 1.4em;
	}
	.now-footer {
		margin-top: 3em;
		padding-top: 1.5em;
		border-top: 1px solid rgb(var(--gray-light));
		font-size: 0.9rem;
		color: rgb(var(--gray));
	}
</style>
